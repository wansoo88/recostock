# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# Raw data — large, re-downloadable. Use `/*` (not a bare `data/raw/`) so git
# still descends into subdirectories we selectively re-include below: a bare
# directory exclude can never be undone by a later `!` rule (git won't list an
# excluded directory's contents at all).
data/raw/*
# EXCEPTION: the SPY put/call history accumulates one row per trading day and is
# NOT re-downloadable (yfinance carries no historical CBOE put/call), so it must
# be committed like data/logs/ and data/paper/. Descend into options/ and
# re-include only the CSV; the re-downloadable vol parquets there stay ignored.
!data/raw/options/
data/raw/options/*
!data/raw/options/spy_pc_daily.csv

# Secrets
.env
deploy/.env
*.key
*.pem

# Intraday trade DB (runtime, not committed)
data/intraday_trades.db

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Model weights ARE committed (models/weights/); exclude training artifacts
models/checkpoints/
models/runs/

data/raw/single_stocks.parquet
