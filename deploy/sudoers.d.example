# /root/recostock 경로를 사용하고 root로 실행하므로 별도 sudoers 설정 불필요.
# self-hosted runner도 root 계정으로 등록하면 systemctl을 직접 실행 가능.
#
# runner를 root가 아닌 별도 계정(예: runner)으로 등록한 경우에만 아래 설정 필요:
# sudo visudo -f /etc/sudoers.d/recostock
#
# runner ALL=(ALL) NOPASSWD: /bin/systemctl restart intraday-bot, \
#                             /bin/systemctl start intraday-bot, \
#                             /bin/systemctl stop intraday-bot, \
#                             /bin/systemctl is-active intraday-bot, \
#                             /bin/journalctl -u intraday-bot *
